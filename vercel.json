{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_BACKEND_URL/api/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://YOUR_BACKEND_URL/static/:path*"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/frontend/:path*"
    },
    {
      "source": "/(styles.css|app.js)",
      "destination": "/frontend/$1"
    },
    {
      "source": "/((?!frontend/).*)",
      "destination": "/frontend/index.html"
    }
  ]
}
